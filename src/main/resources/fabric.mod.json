{
  "schemaVersion": 1,
  "id": "handshaders",
  "version": "${version}",
  "name": "HandShaders",
  "description": "First-person hand and held-item outline shaders with fill and image compositing.",
  "authors": [
    "Codex"
  ],
  "contact": {},
  "license": "All-Rights-Reserved",
  "environment": "client",
  "entrypoints": {
    "client": [
      {
        "adapter": "kotlin",
        "value": "me.cheater.handshaders.HandShadersClient"
      }
    ]
  },
  "mixins": [
    {
      "config": "handshaders.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-language-kotlin": ">=${kotlin_loader_version}",
    "fabric": "*",
    "minecraft": "${minecraft_version}"
  }
}
